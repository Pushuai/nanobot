{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Nanobot Desktop",
  "version": "0.1.0",
  "identifier": "com.nanobot.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Nanobot Desktop",
        "width": 1400,
        "height": 900,
        "minWidth": 980,
        "minHeight": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": [
      "msi"
    ],
    "icon": [
      "icons/icon.ico"
    ],
    "resources": [
      "../resources/backend/*"
    ],
    "windows": {
      "wix": {
        "language": "en-US"
      }
    }
  }
}
