{
  "providers": {
    "openrouter": {
      "apiKey": "sk-or-v1-your_api_key"
    }
  },
  "agents": {
    "defaults": {
      "workspace": "~/.nanobot/workspace",
      "model": "anthropic/claude-opus-4-5"
    }
  },
  "channels": {
    "desktop": {
      "enabled": false,
      "allowFrom": [],
      "defaultChatId": "desktop-ui"
    },
    "feishu": {
      "enabled": true,
      "appId": "cli_xxx",
      "appSecret": "xxx",
      "encryptKey": "",
      "verificationToken": "",
      "allowFrom": []
    }
  },
  "desktop": {
    "enabled": false,
    "host": "127.0.0.1",
    "port": 18791,
    "authToken": "",
    "autoStart": true,
    "minimizeToTray": true,
    "connectTimeoutMs": 3000
  },
  "codex": {
    "enabled": true,
    "commandPrefix": "/cx",
    "codexPath": "codex",
    "model": "gpt-5.3-codex",
    "sandbox": "danger-full-access",
    "approvalPolicy": "never",
    "reasoningMode": "xhigh",
    "useTempWorkspace": true,
    "tempWorkspaceRoot": "",
    "stream": {
      "enabled": true,
      "minIntervalSeconds": 12,
      "maxLines": 30,
      "maxChars": 1200
    }
  },
  "antigravity": {
    "enabled": false,
    "commandPrefix": "/ag",
    "codexPath": "antigravity",
    "sandbox": "danger-full-access",
    "approvalPolicy": "never",
    "reasoningMode": "xhigh",
    "useTempWorkspace": true,
    "tempWorkspaceRoot": "",
    "stream": {
      "enabled": true,
      "minIntervalSeconds": 12,
      "maxLines": 30,
      "maxChars": 1200
    }
  },
  "tools": {
    "exec": {
      "directEnabled": true,
      "directPrefix": "/exec",
      "directAllowPatterns": [".*"],
      "approvalEnabled": true,
      "approvalModelEnabled": true,
      "approvalModel": "",
      "approvalModelMinLevel": "medium",
      "approvalModelMaxTokens": 200,
      "approvalModelTemperature": 0.0,
      "approvalModelRequireOnError": false
    }
  }
}
